# Copy to .env.local — never commit real secrets.
# Staging (Digital Ocean / subdomain): https://overwatch.isoflux.app

# ── Core ─────────────────────────────────────────────────────────
DATABASE_URL=
GROQ_API_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Canonical site URL (SEO, sitemap, metadata) — use staging or production origin
NEXT_PUBLIC_SITE_URL=https://overwatch.isoflux.app
# App origin for redirects (Lemon Squeezy checkout return, proposal links)
NEXT_PUBLIC_APP_URL=https://overwatch.isoflux.app

# ── Lemon Squeezy (merchant of record) ───────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs from Lemon Squeezy dashboard (Products → variant)
LEMONSQUEEZY_VARIANT_AEGIS_PAY=
LEMONSQUEEZY_VARIANT_OVERWATCH_PRO=
# Single-SKU fallback: unlocks both entitlements in webhook mapping
LEMONSQUEEZY_DEFAULT_VARIANT_ID=
# Optional: license validation product label
LEMONSQUEEZY_AEGIS_PAY_PRODUCT_NAME=Aegis-Pay Terminal

# ── Optional ─────────────────────────────────────────────────────
PROPOSAL_IP_SALT=
NOMINATIM_CONTACT_EMAIL=
STRATEGIST_MAX_PER_HOUR=40

# OSM harvest: max viewport area (square degrees). Client clamps the map view to this before Overpass.
# OVERPASS_MAX_BBOX_AREA_SQ_DEG=0.28
# NEXT_PUBLIC_OVERPASS_MAX_BBOX_AREA_SQ_DEG=0.28
